    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.output || $json.text || $json.response || $json.data || \"\";\n\nlet parsed = {};\n\nif (typeof raw === \"string\") {\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    parsed = {\n      sentiment: \"Unknown\",\n      urgency: \"Unknown\",\n      category: \"Unknown\",\n      summary: raw,\n      reply_draft: \"\",\n      escalate: false,\n      parse_error: \"AI did not return valid JSON\"\n    };\n  }\n} else if (raw && typeof raw === \"object\" && !Array.isArray(raw)) {\n  parsed = raw;\n} else {\n  parsed = {\n    sentiment: \"Unknown\",\n    urgency: \"Unknown\",\n    category: \"Unknown\",\n    summary: \"No valid AI output received\",\n    reply_draft: \"\",\n    escalate: false,\n    parse_error: \"Empty or invalid AI output\"\n  };\n}\n\nreturn {\n  json: {\n    ...$json,\n    ...parsed\n    }\n};"
      },
